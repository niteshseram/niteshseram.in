{
  "name": "niteshseram.in",
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint src --fix --cache",
    "format": "lint-staged",
    "prepare": "husky install",
    "precommit": "pnpm lint && lint-staged",
    "postinstall": "prisma generate && npm run cl",
    "tc": "tsc",
    "check": "pnpm run tc && pnpm run lint",
    "format:check": "prettier --check \"**/*.{ts,tsx,mdx}\" --cache",
    "format:fix": "prettier --write \"**/*.{ts,tsx,mdx}\" --cache",
    "cl": "contentlayer2 build"
  },
  "lint-staged": {
    "**/*.{ts,tsx,mdx}": [
      "prettier --write --cache"
    ]
  },
  "dependencies": {
    "@base-ui-components/react": "1.0.0-beta.7",
