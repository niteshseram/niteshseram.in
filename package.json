    "@vercel/og": "^0.5.4",
    "canvas-confetti": "^1.6.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^1.2.1",
    "date-fns": "^2.30.0",
    "lodash-es": "^4.17.21",
    "mdx-bundler": "^10.1.1",
    "motion": "^12.23.24",
    "next": "16.0.10",
    "next-themes": "^0.4.6",
    "ogl": "^1.0.11",
    "react": "19.2.0",
    "react-dom": "19.2.0",
    "react-icons": "^4.8.0",
    "react-use": "^17.4.0",
    "swr": "^2.1.5",
